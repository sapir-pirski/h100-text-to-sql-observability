# Fast-verifier H100 SLO profile used for the final 10.5 RPS / 300s run.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

AGENT_HOST=0.0.0.0
AGENT_PORT=8001
AGENT_WORKERS=8
AGENT_FAST_VERIFY=1
AGENT_MAX_ITERATIONS=3
AGENT_REVISION_STOP_AFTER_ITERATION=3
AGENT_STRICT_VERIFY_HEURISTICS=0

LLM_GENERATE_MAX_TOKENS=128
LLM_VERIFY_MAX_TOKENS=48
LLM_REVISE_MAX_TOKENS=128
LLM_MAX_TOKENS=128
LLM_REQUEST_TIMEOUT_SECONDS=45
SQLITE_QUERY_TIMEOUT_SECONDS=2

SCHEMA_PRUNING=1
SCHEMA_MAX_TABLES=6
VALUE_GROUNDING=1
VALUE_GROUNDING_MAX_PHRASES=16
VALUE_GROUNDING_MAX_COLUMNS=32
VALUE_GROUNDING_LIMIT_PER_PHRASE=2
VALUE_GROUNDING_MAX_MATCHES=16
VALUE_GROUNDING_MAX_VALUE_CHARS=100
VALUE_GROUNDING_ALLOW_CONTAINS=0

VLLM_MAX_MODEL_LEN=6144
VLLM_MAX_NUM_SEQS=48
VLLM_MAX_NUM_BATCHED_TOKENS=24576
VLLM_GPU_MEMORY_UTILIZATION=0.94

LOAD_RPS=10.5
LOAD_DURATION=300
LOAD_OUT_FILE=results/load_test_10_5rps_300s_full_agent_final.json
LOAD_REQUEST_TIMEOUT_SECONDS=90
LOAD_WARMUP_UNIQUE=0

LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
