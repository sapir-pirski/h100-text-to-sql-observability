# Optional OpenAI-compatible backend profile for agent graph debugging.
# Put the actual key in .env or the shell, not in this file.
BACKEND=openai
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_FALLBACK_MODEL=gpt-4o-mini

AGENT_HOST=0.0.0.0
AGENT_PORT=8001
AGENT_WORKERS=4
AGENT_FAST_VERIFY=0
AGENT_MAX_ITERATIONS=3
LLM_MAX_TOKENS=256

# OPENAI_API_KEY=sk-...
