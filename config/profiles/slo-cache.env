# Diagnostic cache-backed 10 RPS / 300s comparison profile.
#
# This profile keeps the same vLLM model/backend but optimizes the serving path
# for repeated benchmark traffic: schema pruning reduces prompt size, the agent
# performs one SQL generation attempt, and deterministic warmup populates the
# response cache before the measured five-minute window. Do not cite this as
# final SLO evidence; use full-agent-no-cache.env instead.
BACKEND=vllm
AGENT_WORKERS=16
AGENT_FAST_VERIFY=0
AGENT_MAX_ITERATIONS=1
LLM_MAX_TOKENS=64

SCHEMA_PRUNING=1
SCHEMA_MAX_TABLES=6
VALUE_GROUNDING=1
VALUE_GROUNDING_MAX_VALUE_CHARS=120

AGENT_RESPONSE_CACHE=1
AGENT_RESPONSE_CACHE_PATH=results/agent_response_cache.sqlite
AGENT_RESPONSE_CACHE_VERSION=slo-cache-v1

LOAD_RPS=10
LOAD_DURATION=300
LOAD_WARMUP_UNIQUE=1
LOAD_WARMUP_CONCURRENCY=16
LOAD_REQUEST_TIMEOUT_SECONDS=120

SMOKE_RPS=2
SMOKE_DURATION=30
