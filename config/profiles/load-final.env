# Load-test profile used for the final 10.5 RPS / 300s run.
BACKEND=vllm
LOCAL_VLLM_BASE_URL=http://localhost:8000/v1
LOCAL_VLLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

AGENT_WORKERS=8
AGENT_FAST_VERIFY=0
AGENT_MAX_ITERATIONS=3
AGENT_REVISION_STOP_AFTER_ITERATION=2
AGENT_STRICT_VERIFY_HEURISTICS=0
LLM_GENERATE_MAX_TOKENS=128
LLM_VERIFY_MAX_TOKENS=48
LLM_REVISE_MAX_TOKENS=128
LLM_MAX_TOKENS=128
LLM_REQUEST_TIMEOUT_SECONDS=45
SQLITE_QUERY_TIMEOUT_SECONDS=2

SCHEMA_PRUNING=1
SCHEMA_MAX_TABLES=6
VALUE_GROUNDING=0
VALUE_GROUNDING_MAX_PHRASES=4
VALUE_GROUNDING_MAX_COLUMNS=24
VALUE_GROUNDING_LIMIT_PER_PHRASE=1
VALUE_GROUNDING_MAX_MATCHES=4
VALUE_GROUNDING_MAX_VALUE_CHARS=100

LOAD_RPS=10.5
LOAD_DURATION=300
LOAD_OUT_FILE=results/load_test_10_5rps_300s_full_agent_final.json
LOAD_REQUEST_TIMEOUT_SECONDS=90
LOAD_WARMUP_UNIQUE=0
SMOKE_RPS=2
SMOKE_DURATION=30

LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
